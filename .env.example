APP_NAME=TCG Trove
APP_ENV=development
APP_VERSION=1.0.0
PUBLIC_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=sqlite:///tcg_trove.db
# Production example:
# DATABASE_URL=postgresql+psycopg2://user:password@db-host:5432/tcgtrove
SESSION_SECRET=replace-with-strong-secret-min-32-characters
SESSION_MAX_AGE_SECONDS=86400
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200
ALLOWED_ORIGINS=http://127.0.0.1:3000
API_RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_EVENT_RETENTION_SECONDS=86400
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
MAX_BODY_SIZE_BYTES=10485760
UPLOAD_MAX_BYTES=5242880
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=45
SEED_DEFAULT_ADMIN=true
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tcgtrove.local
SMTP_USE_TLS=true
EMAIL_OUTBOX_WORKER_ENABLED=true
EMAIL_OUTBOX_POLL_SECONDS=20
EMAIL_OUTBOX_BATCH_SIZE=20
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
METRICS_AUTH_TOKEN=change-me-metrics-token
MEDIA_DIR=app/static/uploads
MEDIA_UPLOAD_RETENTION_DAYS=180
INQUIRY_MESSAGE_RETENTION_DAYS=365
SEARCH_LOG_RETENTION_DAYS=365
AUDIT_LOG_RETENTION_DAYS=730
BACKUP_DIR=backups
